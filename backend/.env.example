# Copy to backend/.env and fill with your Alpaca PAPER trading keys.
# Get them at https://app.alpaca.markets/ (Paper Trading -> API Keys)
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here

# Paper trading endpoint. Do not change unless you intend to use real money.
ALPACA_PAPER=true

# Market data feed. "iex" is free; "sip" requires a paid Alpaca data plan.
ALPACA_DATA_FEED=iex

# Comma-separated default watchlist symbols.
DEFAULT_SYMBOLS=AAPL,MSFT,TSLA,SPY
