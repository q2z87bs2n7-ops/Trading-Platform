# Copy to backend/.env and fill with your Alpaca PAPER trading keys.
# Get them at https://app.alpaca.markets/ (Paper Trading -> API Keys)
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here

# Paper trading endpoint. Do not change unless you intend to use real money.
ALPACA_PAPER=true

# Market data feed. "iex" is free; "sip" requires a paid Alpaca data plan.
ALPACA_DATA_FEED=iex

# Comma-separated default watchlist symbols.
DEFAULT_SYMBOLS=AAPL,MSFT,TSLA,SPY

# AI chat (Anthropic). Disabled by default — calls cost real money.
# Get an API key at https://console.anthropic.com (separate account from
# claude.ai). Flip AI_CHAT_ENABLED=true once the key is loaded.
AI_CHAT_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=4096
AI_MAX_TOOL_ITERATIONS=16
# Anthropic hosted web search for the Ask anything bot (~$10/1k searches).
# Requires web search to also be enabled for your org in the Anthropic
# Console; if it's on here but off there, the bot self-heals to internal-only.
AI_WEB_SEARCH_ENABLED=false

# Postgres (Supabase). Optional — when unset, DB-backed features (company
# profiles / catalogue) return a graceful 503, like the Alpaca-keys seam.
# Use the Supabase "Session pooler" URI (IPv4, free) for local + Render +
# Vercel. URL-encode any special chars in the password.
DATABASE_URL=

# Financial Modeling Prep API key (free tier, datacenter-friendly). When set,
# preferred over Yahoo for company profiles. Get one at
# https://financialmodelingprep.com/developer/docs
FMP_API_KEY=

